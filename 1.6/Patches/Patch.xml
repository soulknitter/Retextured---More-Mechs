						<lifeStages>
							<li>
								<bodyGraphicData>
									<texPath>Things/Pawn/Mechanoids/Crawler</texPath>
									<maskPath>Things/Pawn/Mechanoids/AllegianceOverlay/Crawler</maskPath>
									<shaderType>CutoutWithOverlay</shaderType>
									<graphicClass>Graphic_Multi</graphicClass>
									<drawSize>1.6</drawSize>
									<shadowData>
										<volume>(0.4, 0.8, 0.4)</volume>
									</shadowData>
								</bodyGraphicData>
							</li>
							<li>
								<bodyGraphicData>
									<texPath>Things/Pawn/Mechanoids/AncientCrawler</texPath>
